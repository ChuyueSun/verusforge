# Copy to .env and fill in. The server reads this on startup.

# Required: your Anthropic API key.
ANTHROPIC_API_KEY=

# Model (default: claude-opus-4-8)
ANTHROPIC_MODEL=claude-opus-4-8

# Path to the Verus binary. Point this at your built Verus, e.g.:
#   ~/verus/source/target-verus/release/verus
# Leave blank or unset to skip the proof step (spec + code generation still run).
VERUS_BIN=

# Directory containing rustup/cargo (Verus shells out to rustup).
# Defaults to ~/.cargo/bin — only set if yours is elsewhere.
# RUST_BIN_PATH=~/.cargo/bin

# Max proof-repair iterations before giving up (default: 4)
# MAX_REPAIRS=4

# Per-verification timeout in ms (default: 60000)
# VERUS_TIMEOUT_MS=60000

# API port (default: 8787)
# PORT=8787
